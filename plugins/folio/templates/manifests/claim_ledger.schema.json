{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claim Ledger",
  "description": "Maps paper claims to evidence sources and support levels",
  "type": "object",
  "required": ["claims"],
  "properties": {
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement", "type", "support_level"],
        "properties": {
          "id": { "type": "string", "pattern": "^C\\d+$" },
          "statement": { "type": "string" },
          "type": { "type": "string", "enum": ["quantitative", "qualitative", "methodological", "fact", "interpretation", "opinion", "forecast"] },
          "evidence_source": { "type": "string" },
          "support_level": { "type": "string", "enum": ["strong", "moderate", "weak", "unsupported"] },
          "depends_on_figures": { "type": "array", "items": { "type": "string" } },
          "depends_on_citations": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
