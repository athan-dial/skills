{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Materials Passport",
  "description": "Per-material provenance, classification, and allowed-use policy",
  "type": "object",
  "required": ["materials"],
  "properties": {
    "materials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "material_id",
          "source_type",
          "classification",
          "allowed_use"
        ],
        "properties": {
          "material_id": { "type": "string" },
          "source_type": {
            "type": "string",
            "enum": [
              "internal_data",
              "public_data",
              "literature",
              "proprietary_doc",
              "code"
            ]
          },
          "classification": {
            "type": "string",
            "enum": ["public", "internal", "confidential"]
          },
          "allowed_use": {
            "type": "string",
            "enum": ["cite", "reference", "embed", "redact_and_reference"]
          },
          "summary": { "type": "string" },
          "redaction_required": {
            "type": "boolean",
            "default": false
          }
        }
      }
    }
  }
}
