#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: bin/gen-commands-doc <plugin-name>" >&2
  exit 1
}

err() {
  echo "gen-commands-doc: $*" >&2
  exit 1
}

escape_pipes() {
  printf '%s' "$1" | sed 's/|/\\|/g'
}

extract_field() {
  field_name=$1
  file_path=$2

  awk -v field="$field_name" '
    NR == 1 && $0 == "---" { in_frontmatter = 1; next }
    in_frontmatter && $0 == "---" { exit }
    in_frontmatter && $0 ~ ("^" field ":[[:space:]]*") {
      sub("^" field ":[[:space:]]*", "", $0)
      print
      exit
    }
  ' "$file_path"
}

script_dir=$(cd "$(dirname "$0")" && pwd)
repo_root=$(cd "$script_dir/.." && pwd)

[ "$#" -eq 1 ] || usage

plugin_name=$1
plugin_dir="$repo_root/plugins/$plugin_name"
commands_dir="$plugin_dir/commands"

[ -d "$plugin_dir" ] || err "plugins/$plugin_name does not exist"

if [ ! -d "$commands_dir" ]; then
  echo "no commands/ dir, skipping"
  exit 0
fi

docs_path="$plugin_dir/docs/reference/commands.md"
mkdir -p "$(dirname "$docs_path")"
tmp_file=$(mktemp)
trap 'rm -f "$tmp_file"' EXIT

{
  echo "<!-- generated by bin/gen-commands-doc — do not edit by hand -->"
  echo "---"
  printf 'title: "Commands"\n'
  printf 'description: "All /%s:* slash commands."\n' "$plugin_name"
  printf 'weight: 40\n'
  echo "---"
  echo
  printf 'Auto-generated from `plugins/%s/commands/*.md` frontmatter.\n' "$plugin_name"
  echo
  echo "| Command | Arguments | Description |"
  echo "|---|---|---|"
} > "$tmp_file"

find "$commands_dir" -maxdepth 1 -type f -name '*.md' | sort | while IFS= read -r file; do
  command_name=$(basename "$file" .md)
  description=$(extract_field "description" "$file" || true)
  argument_hint=$(extract_field "argument-hint" "$file" || true)

  [ -n "$description" ] || description="—"
  [ -n "$argument_hint" ] || argument_hint="—"

  printf '| `/%s:%s` | %s | %s |\n' \
    "$plugin_name" \
    "$command_name" \
    "$(escape_pipes "$argument_hint")" \
    "$(escape_pipes "$description")" >> "$tmp_file"
done

command_count=$(find "$commands_dir" -maxdepth 1 -type f -name '*.md' | wc -l | tr -d ' ')
mv "$tmp_file" "$docs_path"
trap - EXIT

echo "Generated plugins/$plugin_name/docs/reference/commands.md ($command_count commands)"
